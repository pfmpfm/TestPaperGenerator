# ==================== 应用配置 ====================
APP_NAME=ExamGenerator
APP_VERSION=1.0.0
ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-me-in-production

# ==================== 数据库配置 ====================
# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root_password_change_me
MYSQL_DATABASE=exam_generator

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ==================== LLM配置 ====================
# 通义千问 (默认)
QWEN_API_KEY=your-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek (备选)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-chat
DEEPSEEK_COST_EFFICIENT_MODEL=deepseek-chat

# 智谱AI (备选)
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_HIGH_QUALITY_MODEL=glm-4-plus
ZHIPU_COST_EFFICIENT_MODEL=glm-4-flash
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSION=2048

# Kimi (备选)
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_HIGH_QUALITY_MODEL=moonshot-v1-32k
KIMI_COST_EFFICIENT_MODEL=moonshot-v1-8k

# 百川 (备选)
BAICHUAN_API_KEY=your-baichuan-api-key
BAICHUAN_BASE_URL=https://api.baichuan-ai.com/v1
BAICHUAN_EMBEDDING_MODEL=Baichuan-Text-Embedding
BAICHUAN_EMBEDDING_DIMENSION=1024

# 本地 Embedding (备选)
LOCAL_EMBEDDING_MODEL_PATH=./models/bge-large-zh-v1.5
LOCAL_EMBEDDING_DIMENSION=1024
LOCAL_EMBEDDING_DEVICE=cuda

# ==================== 模型配置 ====================
# 当前使用的LLM提供商 (deepseek/zhipu/kimi/qwen)
LLM_PROVIDER=qwen
# 高质量模型
LLM_HIGH_QUALITY_MODEL=qwen3.7-plus
# 成本优化模型
LLM_COST_EFFICIENT_MODEL=qwen3.7-plus

# 当前使用的Embedding提供商
EMBEDDING_PROVIDER=qwen
# Embedding模型
EMBEDDING_MODEL=text-embedding-v3
# 向量维度
EMBEDDING_DIMENSION=2048

# ==================== LangSmith配置 ====================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=exam-generator-mvp

# ==================== 文件存储配置 ====================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=50  # MB

# 配图存储（Docker环境使用/app/static/figures，本地开发使用./static/figures）
FIGURE_DIR=./static/figures
FIGURE_URL_PREFIX=/static/figures

# OSS配置 (可选，用于生产环境)
OSS_PROVIDER=aliyun  # aliyun/qiniu/local
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=

# ==================== 安全配置 ====================
# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 内容安全API (可选)
CONTENT_SAFETY_PROVIDER=baidu  # baidu/aliyun/none
CONTENT_SAFETY_API_KEY=
CONTENT_SAFETY_SECRET_KEY=

# ==================== 服务配置 ====================
# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# 并发控制
MAX_CONCURRENT_LLM_CALLS=3
MAX_CONCURRENT_GENERATION_SESSIONS=5

# 超时配置 (秒)
LLM_TIMEOUT=60
TOOL_TIMEOUT=30
WORKFLOW_TIMEOUT=300

# 重试配置
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2

# ==================== 监控配置 ====================
# Prometheus
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Sentry (可选)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ==================== 其他配置 ====================
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# 日志格式 (json/text)
LOG_FORMAT=json

# 时区
TIMEZONE=Asia/Shanghai
